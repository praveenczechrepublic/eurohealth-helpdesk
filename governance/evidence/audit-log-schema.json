{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "EuroHealth Audit Log Entry (PEP + Interaction Trace)",
  "description": "Structured audit log entry to support EU AI Act Article 12 record-keeping. Captures PEP decision plus sufficient trace to reconstruct an interaction (query->retrieval->policy->response->HITL).",
  "type": "object",
  "required": [
    "event_id",
    "timestamp_utc",
    "event_type",
    "session_id",
    "actor",
    "request",
    "decision",
    "model",
    "latency_ms",
    "integrity"
  ],
  "properties": {
    "event_id": {
      "type": "string",
      "description": "Unique identifier for this audit event (UUID)."
    },
    "correlation_id": {
      "type": "string",
      "description": "Links multiple audit events in the same end-to-end interaction (e.g., retrieval, pep_decision, response_written, human_override)."
    },
    "timestamp_utc": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp (UTC)."
    },
    "event_type": {
      "type": "string",
      "enum": [
        "interaction_started",
        "retrieval_completed",
        "pep_decision",
        "response_written",
        "human_override",
        "escalation",
        "system_error"
      ],
      "description": "Type of audit event."
    },
    "session_id": {
      "type": "string",
      "description": "Unique session identifier."
    },
    "actor": {
      "type": "object",
      "required": ["user_pseudonym", "role"],
      "properties": {
        "user_pseudonym": {
          "type": "string",
          "description": "Stable pseudonymized employee identifier (no raw employee ID in logs)."
        },
        "role": {
          "type": "string",
          "enum": ["employee", "helpdesk_agent", "admin", "system"],
          "description": "Actor role."
        }
      }
    },
    "request": {
      "type": "object",
      "required": ["language", "query_hash"],
      "properties": {
        "language": {
          "type": "string",
          "enum": ["EN", "DE", "CZ"]
        },
        "query_hash": {
          "type": "string",
          "description": "SHA-256 hash of the original query (not the query itself)."
        },
        "contains_pii_flag": {
          "type": "boolean",
          "description": "True if PII detector flagged potential PII in the request."
        }
      }
    },
    "retrieval": {
      "type": "object",
      "properties": {
        "kb_source": {
          "type": "string",
          "description": "Knowledge source (e.g., Confluence, SharePoint, KB)."
        },
        "kb_version": {
          "type": ["string", "null"],
          "description": "Version/commit/hash of the KB snapshot used for retrieval."
        },
        "sources_used": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Document/page IDs used as context."
        }
      }
    },
    "decision": {
      "type": "object",
      "required": ["action"],
      "properties": {
        "action": {
          "type": "string",
          "enum": ["allow", "block", "redirect", "escalate", "redact"],
          "description": "PEP enforcement decision."
        },
        "policy": {
          "type": ["string", "null"],
          "description": "Policy name that triggered the decision (null if allow)."
        },
        "rule_id": {
          "type": ["string", "null"],
          "description": "Specific rule ID within the policy."
        },
        "reason": {
          "type": ["string", "null"],
          "description": "Short justification for the decision (no PII)."
        },
        "pii_types": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Types of PII detected (empty if none)."
        },
        "escalated_to": {
          "type": ["string", "null"],
          "description": "Target of escalation (null if not escalated)."
        }
      }
    },
    "model": {
      "type": "object",
      "required": ["model_version"],
      "properties": {
        "model_version": {
          "type": "string",
          "description": "LLM model and version used for generation."
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "Generator confidence score (if available)."
        }
      }
    },
    "response": {
      "type": "object",
      "properties": {
        "response_hash": {
          "type": ["string", "null"],
          "description": "SHA-256 hash of the final response (enables reconstruction proof without storing full text)."
        },
        "response_status": {
          "type": ["string", "null"],
          "enum": ["served", "blocked", "redacted", "escalated", "error"],
          "description": "Outcome of the interaction."
        }
      }
    },
    "human_override": {
      "type": "object",
      "properties": {
        "override_invoked": { "type": "boolean" },
        "override_actor_role": {
          "type": ["string", "null"],
          "enum": ["helpdesk_agent", "admin"]
        },
        "override_reason": { "type": ["string", "null"] },
        "override_timestamp_utc": {
          "type": ["string", "null"],
          "format": "date-time"
        }
      }
    },
    "latency_ms": {
      "type": "object",
      "required": ["policy_evaluation", "total"],
      "properties": {
        "retrieval": { "type": "integer" },
        "generation": { "type": "integer" },
        "policy_evaluation": { "type": "integer" },
        "total": { "type": "integer" }
      }
    },
    "integrity": {
      "type": "object",
      "required": ["storage_class", "record_hash"],
      "properties": {
        "storage_class": {
          "type": "string",
          "enum": ["append_only", "wორმ_worm", "immutable_bucket"],
          "description": "Storage immutability class used for audit logs."
        },
        "record_hash": {
          "type": "string",
          "description": "Hash of the entire record for tamper-evidence."
        }
      }
    }
  },
  "additionalProperties": false
}